{
  "manifest_version": 3,
  "name": "Asmara Personal New Tab",
  "version": "1.0",
  "description": "Halaman New Tab personal yang didesain untuk produktivitas.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"]
}
